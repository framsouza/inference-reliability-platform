flowchart LR
  subgraph sources[Signal sources]
    vllm[vLLM pod<br/>/metrics + OTLP + stdout]
    epp[EPP<br/>/metrics scoring stats]
    dcgm[DCGM exporter]
    ksm[kube-state-metrics]
    ne[node-exporter]
    egdp[Envoy Gateway data-plane<br/>/stats]
    eval[model-quality-eval<br/>CronWorkflow]
  end

  subgraph collect[Collection]
    otel[OTel collector<br/>DaemonSet]
    pushgw[Pushgateway<br/>batch metrics]
    prom[Prometheus<br/>6h local retention]
  end

  subgraph store[Long-term stores]
    loki[Loki<br/>168h retention]
    tempo[Tempo]
  end

  subgraph consume[Consumption]
    graf[Grafana<br/>dashboards: vLLM, GPU, model-quality]
    am[Alertmanager]
    rules[PrometheusRule<br/>SLO + GPU + model-quality]
  end

  vllm -->|OTLP traces| otel
  vllm -->|/metrics scrape 15s| prom
  vllm --> stdout[stdout] --> otel
  epp -->|/metrics scrape 15s| prom
  dcgm -->|scrape| prom
  ksm -->|scrape| prom
  ne -->|scrape| prom
  egdp -->|/stats| prom
  eval -->|prom_client push| pushgw
  pushgw -->|scrape 15s| prom

  otel -->|traces| tempo
  otel -->|logs| loki
  otel -->|remote_write| prom

  prom --> rules
  rules --> am
  prom --> graf
  loki --> graf
  tempo --> graf

  graf -.exemplars.-> tempo
  tempo -.derived logs.-> loki
